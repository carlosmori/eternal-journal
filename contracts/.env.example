# Private key of the wallet that deploys the contract (without 0x)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Owner address (Safe multisig in production)
# Used as DEFAULT_ADMIN_ROLE, PAUSER_ROLE, UPGRADER_ROLE, and FEE_MANAGER_ROLE
# If not set, uses the deployer wallet
OWNER_ADDRESS=0x_your_safe_multisig_address
