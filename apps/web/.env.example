# WalletConnect Cloud Project ID (obligatorio para RainbowKit)
# Obtén uno gratis en https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Backend URL (server-side only, never exposed to browser)
# All frontend API calls go through the /api/backend proxy route handler
BACKEND_URL=http://localhost:3001

# Admin email (for showing admin link in UI; real security is in the backend)
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com
